---
interface Props {
  images: string[]
  title:  string
}

const { images, title } = Astro.props
---

<div class="mb-5 animate-fade-up" style="animation-delay: 0.2s;">
  <p class="text-[10px] tracking-widest uppercase text-muted mb-3 font-mono">galeria</p>

  <!-- Thumbnail grid -->
  <div class="grid gap-1.5" style="grid-template-columns: repeat(2, 1fr);">
    {images.map((src, i) => (
      <button
        class="gallery-thumb cursor-pointer relative overflow-hidden rounded-lg border border-line2 transition-all duration-200 hover:border-lime-border focus:outline-none focus:ring-1 group"
        style="height: 120px; background: var(--color-surface2);"
        data-index={i}
        aria-label={`Open image ${i + 1}`}
      >
        <img
          src={src}
          alt={`${title} screenshot ${i + 1}`}
          class="w-full h-full object-cover transition-opacity duration-200 group-hover:opacity-90"
          loading="lazy"
        />
        <!-- hover overlay -->
        <div
          class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-200 flex items-center justify-center"
          style="background: rgba(10,10,10,0.4);"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M2 2H6M2 2V6M2 2L6.5 6.5M14 2H10M14 2V6M14 2L9.5 6.5M2 14H6M2 14V10M2 14L6.5 9.5M14 14H10M14 14V10M14 14L9.5 9.5" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
      </button>
    ))}
  </div>
</div>

<!-- ── Lightbox dialog ─────────────────────────────────────────────────── -->
<dialog
  id="gallery-lightbox"
  class="fixed inset-0 z-50 p-0 border-0 w-full h-full max-w-none max-h-none"
  style="background: rgba(10,10,10,0.95); backdrop-filter: blur(12px);"
>
  <div class="flex flex-col items-center justify-center h-full gap-4 p-6">

    <!-- Close button -->
    <button
      id="lb-close"
      class="absolute cursor-pointer top-5 right-5 w-9 h-9 rounded-lg flex items-center justify-center transition-colors duration-200"
      style="background: var(--color-surface2); border: 1px solid var(--color-line2); color: var(--color-muted);"
      aria-label="Close"
    >
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <!-- Main image -->
    <img
      id="lb-image"
      src=""
      alt=""
      class="max-h-[80vh] max-w-full object-contain rounded-xl"
      style="border: 1px solid var(--color-line2);"
    />

    <!-- Counter + nav -->
    <div class="flex items-center gap-4">
      <button
        id="lb-prev"
        class="w-9 h-9 cursor-pointer rounded-lg flex items-center justify-center transition-colors duration-200"
        style="background: var(--color-surface2); border: 1px solid var(--color-line2); color: var(--color-muted);"
        aria-label="Previous"
      >
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M8 1L3 6L8 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <span id="lb-counter" class="text-xs font-mono text-muted tabular-nums">1 / 1</span>

      <button
        id="lb-next"
        class="w-9 h-9 cursor-pointer rounded-lg flex items-center justify-center transition-colors duration-200"
        style="background: var(--color-surface2); border: 1px solid var(--color-line2); color: var(--color-muted);"
        aria-label="Next"
      >
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
          <path d="M4 1L9 6L4 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</dialog>

<script define:vars={{ images }}>
  const lightbox  = document.getElementById('gallery-lightbox')
  const lbImage   = document.getElementById('lb-image')
  const lbCounter = document.getElementById('lb-counter')
  const lbClose   = document.getElementById('lb-close')
  const lbPrev    = document.getElementById('lb-prev')
  const lbNext    = document.getElementById('lb-next')
  const thumbs    = document.querySelectorAll('.gallery-thumb')

  let current = 0

  function open(index) {
    current = index
    update()
    lightbox.showModal()
  }

  function update() {
    lbImage.src     = images[current]
    lbImage.alt     = `Image ${current + 1}`
    lbCounter.textContent = `${current + 1} / ${images.length}`
  }

  thumbs.forEach((btn) => {
    btn.addEventListener('click', () => open(Number(btn.dataset.index)))
  })

  lbClose.addEventListener('click', () => lightbox.close())
  lbPrev.addEventListener('click',  () => { current = (current - 1 + images.length) % images.length; update() })
  lbNext.addEventListener('click',  () => { current = (current + 1) % images.length; update() })

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) lightbox.close()
  })

  document.addEventListener('keydown', (e) => {
    if (!lightbox.open) return
    if (e.key === 'ArrowLeft')  { current = (current - 1 + images.length) % images.length; update() }
    if (e.key === 'ArrowRight') { current = (current + 1) % images.length; update() }
    if (e.key === 'Escape')     lightbox.close()
  })
</script>

<style>
  dialog::backdrop {
    background: transparent;
  }
  .gallery-thumb:hover {
    border-color: var(--color-lime-border) !important;
  }
</style>
