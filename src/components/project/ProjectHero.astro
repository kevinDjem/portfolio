---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
  image?: ImageMetadata
  type?: string
  date?: string | null
  title: string
  slug: string
}

const { image, type, date, title, slug } = Astro.props

const typeColors: Record<string, string> = {
  fullstack: 'var(--color-lime)',
  frontend:  '#60a5fa',
  backend:   '#a78bfa',
  mobile:    '#fb923c',
  other:     'var(--color-muted)',
}

const accentColor = type ? (typeColors[type] ?? typeColors.other) : typeColors.other
---

<figure transition:name={`project-${slug}`} class="relative overflow-hidden rounded-xl border border-line2 bg-surface2">
  {image ? (
    <Image
      src={image}
      alt={`${title} preview`}
      class="object-cover"
      loading="eager"
      fetchpriority="high"
    />
  ) : (
    <!-- Placeholder pattern when no image -->
    <div class="aspect-video flex items-center justify-center bg-surface2">
      <div class="flex flex-col items-center gap-3 opacity-20">
        <svg width="48" height="36" viewBox="0 0 48 36" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="1" y="1" width="46" height="34" rx="5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M1 26L12 16L20 24L30 14L47 26" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
          <circle cx="15" cy="10" r="4" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        <span class="text-xs font-mono text-current">no image</span>
      </div>
    </div>
  )}

  <!-- Gradient overlay for readability -->
  {image && (
    <div
      class="animate-fade-up delay-2 absolute inset-0 pointer-events-none"
      style="background: linear-gradient(to top, rgba(10,10,10,0.6) 0%, transparent 50%);"
    />
  )}

  <!-- Date badge — top left -->
  <!-- {date && (
    <div
      class="absolute top-3 left-3 px-2.5 py-1 rounded text-[10px] font-mono"
      style="background: rgba(10,10,10,0.75); border: 1px solid var(--color-line2); color: var(--color-muted); backdrop-filter: blur(8px);"
    >
      {date}
    </div>
  )} -->

  <!-- Type badge — top right -->
  {type && (
    <div
      class="absolute top-3 right-3 px-2.5 py-1 rounded text-[10px] font-mono tracking-widest uppercase"
      style={`background: rgba(10,10,10,0.75); border: 1px solid ${accentColor}33; color: ${accentColor}; backdrop-filter: blur(8px);`}
    >
      {type}
    </div>
  )}
</figure>
