---
import ProjectLinks from './ProjectLinks.astro'

interface Props {
  type?:         string
  date?:         string | null
  featured?:     boolean
  technologies:  string[]
  githubUrl?:    string
  demoUrl?:      string
}

const { type, date, featured, technologies, githubUrl, demoUrl } = Astro.props

const typeColors: Record<string, string> = {
  fullstack: 'var(--color-lime)',
  frontend:  '#60a5fa',
  backend:   '#a78bfa',
  mobile:    '#fb923c',
  other:     'var(--color-muted)',
}

const accentColor = type ? (typeColors[type] ?? typeColors.other) : typeColors.other
---

<aside
  class="flex flex-col gap-3 animate-fade-up"
  style="animation-delay: 0.2s; position: sticky; top: calc(var(--nav-height) + 20px); align-self: start;"
>

  <!-- Back button -->
  <a
    href="/#projects"
    class="inline-flex items-center gap-2 rounded-lg text-xs font-mono transition-all duration-200 hover:text-ink group"
    style="
      background: var(--color-surface);
      border: 1px solid var(--color-line);
      color: var(--color-muted);
      padding: 7px 12px;
    "
  >
    <span class="group-hover:-translate-x-0.5 transition-transform duration-200">←</span>
    volver a proyectos
  </a>

  <!-- ── Metadata card ───────────────────────────────────────────────── -->
  <div
    class="rounded-xl p-3.5"
    style="background: var(--color-surface); border: 1px solid var(--color-line);"
  >
    <p class="text-[10px] tracking-widest uppercase font-mono mb-3"
       style="color: var(--color-muted);"
    >
      project info
    </p>

    <div class="flex flex-col gap-0">

      {type && (
        <div
          class="flex items-center justify-between py-2 border-b"
          style="border-color: var(--color-line);"
        >
          <span class="text-[11px] font-mono" style="color: var(--color-muted);">type</span>
          <span
            class="text-[11px] font-mono tracking-wide uppercase"
            style={`color: ${accentColor};`}
          >
            {type}
          </span>
        </div>
      )}

      {date && (
        <div
          class="flex items-center justify-between py-2 border-b"
          style="border-color: var(--color-line);"
        >
          <span class="text-[11px] font-mono" style="color: var(--color-muted);">date</span>
          <span class="text-[11px] font-mono" style="color: var(--color-ink);">{date}</span>
        </div>
      )}

      <div class="flex items-center justify-between py-2">
        <span class="text-[11px] font-mono" style="color: var(--color-muted);">status</span>
        <span class="flex items-center gap-1.5 text-[11px] font-mono" style="color: var(--color-ink);">
          <span
            class="w-1.5 h-1.5 rounded-full"
            style={featured
              ? 'background: var(--color-lime);'
              : 'background: var(--color-faint);'}
          />
          {featured ? 'featured' : 'project'}
        </span>
      </div>
    </div>
  </div>

  <!-- ── Links card ─────────────────────────────────────────────────── -->
  {(githubUrl || demoUrl) && (
    <div
      class="rounded-xl p-3.5"
      style="background: var(--color-surface); border: 1px solid var(--color-line);"
    >
      <p class="text-[10px] tracking-widest uppercase font-mono mb-3"
         style="color: var(--color-muted);"
      >
        links
      </p>
      <ProjectLinks githubUrl={githubUrl} demoUrl={demoUrl} variant="column" />
    </div>
  )}

  <!-- ── Stack card ─────────────────────────────────────────────────── -->
  <div
    class="rounded-xl p-3.5"
    style="background: var(--color-surface); border: 1px solid var(--color-line);"
  >
    <p class="text-[10px] tracking-widest uppercase font-mono mb-3"
       style="color: var(--color-muted);"
    >
      stack
    </p>
    <div class="flex flex-wrap gap-1.5">
      {technologies.map((tech, i) => (
        <span
          class="px-2 py-0.5 rounded text-[10px] font-mono"
          style={i < 2
            ? 'background: var(--color-lime-dim); border: 1px solid var(--color-lime-border); color: var(--color-lime);'
            : 'background: var(--color-surface2); border: 1px solid var(--color-line2); color: var(--color-muted);'
          }
        >
          {tech}
        </span>
      ))}
    </div>
  </div>

</aside>
