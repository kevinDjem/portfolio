---
interface Props {
  technologies: string[]
}

const { technologies } = Astro.props
---

<div class="mb-5 animate-fade-up delay-1">
  <p class="text-[10px] tracking-widest uppercase text-muted mb-3 font-mono">Tecnologias</p>
  <div class="flex flex-wrap gap-1.5">
    {technologies.map((tech) => (
      <span
        class="px-2.5 py-1 rounded text-[11px] font-mono transition-colors duration-200 cursor-default text-lime border-lime-border bg-lime-dim border"        
      >
        {tech}
      </span>
    ))}
  </div>
</div>
