---
import { DownloadIcon, GithubIcon, LinkedinIcon } from "../../components/icons/contact"
import { CtaButton, KeywordHighlight, Section } from "../ui"
import KevinDjemdjemian from "/KevinDjemdjemian_CV.pdf"
---

<Section id="home" className="mb-0">
  <article class="min-h-dvh grid place-content-center">
    <section class="relative min-h-screen flex flex-col items-center justify-center text-center overflow-hidden px-6">
      <div class="hero-glow"></div>
      <article class="relative z-10 max-w-3xl mx-auto">
        <h1 class="animate-fade-up delay-2 font-bold leading-[0.95] tracking-tighter mb-6 text-[clamp(3.2rem,10vw,7rem)]">
          <span class="text-ink block animate-fade-up">Kevin</span>
          <span class="block text-outline">Djemdjemian</span>
        </h1>
        <section class="animate-fade-up delay-3 flex items-center justify-center gap-3 mb-7">
          <span class="h-px w-12 bg-line2"></span>
          <span class="font-mono text-sm tracking-widest text-muted uppercase">Full Stack Web Developer</span>
          <span class="h-px w-12 bg-line2"></span>
        </section>
        <p class="animate-fade-up delay-4 text-[1.05rem] text-muted font-light leading-relaxed max-w-xl mx-auto mb-10">
          Analista IT & Fullstack Developer con <KeywordHighlight>5+ años</KeywordHighlight> de experiencia en soporte de aplicaciones y desarrollo, especializado en <KeywordHighlight>React</KeywordHighlight>, <KeywordHighlight>.NET</KeywordHighlight>, <KeywordHighlight>SQL Server</KeywordHighlight> y <KeywordHighlight>APIs REST</KeywordHighlight>, con foco en debugging, performance y estabilidad en entornos productivos.
        </p>
        <section class="animate-fade-up delay-5 flex flex-wrap items-center justify-center gap-3">
          <!-- <CtaButton
            variant="solid"
            href="https://github.com/KevinDjem"
            target="_blank"
            ariaLabel="Ver perfil de GitHub de KevinDjem"
          >
            <GithubIcon class:list="w-4" aria-hidden="true"/>
            <span class="md:inline hidden">Github</span>
          </CtaButton> -->
          <CtaButton
            variant="ghost"
            href="https://www.linkedin.com/in/kevin-djemdjemian-666429398/"
            target="_blank"
            ariaLabel="Ver perfil de LinkedIn de Kevin"
          >
            <LinkedinIcon class:list="w-4" aria-hidden="true"/>
            <span class="md:inline hidden">LinkedIn</span>
          </CtaButton>
          <CtaButton 
            variant="primary" 
            href={KevinDjemdjemian}
            download
            ariaLabel="Descargar CV de Kevin"
          >
            <DownloadIcon class:list="w-4" aria-hidden="true"/>
            <span>Descargar CV</span>
          </CtaButton>
        </section>
      </article>
    </section>
  </article>
</Section>
