---
import type { ImageMetadata } from "astro"
import outfitFont  from '@fontsource-variable/outfit/files/outfit-latin-wght-normal.woff2?url'
import ibmPlexFont from '@fontsource-variable/ibm-plex-sans/files/ibm-plex-sans-latin-wght-normal.woff2?url'

interface Props {
  title: string
  description?: string
  image?: ImageMetadata
}

const { 
  title,
  description = 'Analista IT & Fullstack Developer. Experiencia en React, .NET y SQL Server. Enfocado en debugging, performance y aplicaciones en producción.',
  image 
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href

const ogImage = image 
  ? new URL(image.src, Astro.site).href
  : new URL('/preview.png', Astro.site).href
---

<link rel="preload" href={outfitFont}  as="font" type="font/woff2" crossorigin />
<link rel="preload" href={ibmPlexFont} as="font" type="font/woff2" crossorigin />

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width" />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32"   href="/favicon-32.png" />
<link rel="icon" type="image/png" sizes="48x48"   href="/favicon-48.png" />
<link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
<link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />

<meta name="generator" content={Astro.generator} />

<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content="Kevin Djemdjemian" />

<meta name="keywords" content="Kevin Djemdjemian, Fullstack Developer, .NET Developer, React Developer, SQL Server, Backend Developer, APIs REST, debugging producción, desarrollo web Argentina" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:site_name" content="Kevin Djemdjemian" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<meta name="robots" content="index, follow" />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://kevindjem-portfolio.vercel.app/#person",
  "name": "Kevin Djemdjemian",
  "url": "https://kevindjem-portfolio.vercel.app/",
  "image": "https://kevindjem-portfolio.vercel.app/avatar.webp",
  "jobTitle": "Fullstack Developer / Analista IT",
  "description": description,
  "email": "kfdjem@gmail.com",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "AR"
  },
  "sameAs": [
    "https://github.com/KevinDjem",
    "https://www.linkedin.com/in/kevin-djemdjemian-666429398/"
  ],
  "knowsAbout": [
    "React",
    ".NET",
    "SQL Server",
    "TypeScript",
    "APIs REST",
    "Debugging",
    "Performance"
  ]
})} />