---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets'
import Badge from './Badge.astro';
import { InternalLinkIcon } from '../icons/contact';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { slug } = project
const { title, description, image, technologies } = project.data;
---

<article class="group relative flex flex-col sm:flex-row gap-0 bg-surface rounded-xl overflow-hidden border border-white/6 hover:border-lime/20  transition-colors duration-300">
  <a
    href={`/project/${slug}`}
    class="card-overlay absolute inset-0 z-1 rounded-xl"
    aria-label={`Ver detalles de ${title}`}
  />
  <fugure class="w-full sm:w-[45%] shrink-0 overflow-hidden bg-black">
    <Image
      src={image}      
      alt={`Screenshot of ${title}`}
      width="640"
      height="360"
      quality={75}
      loading="lazy"
      decoding="async"
      format='webp'
      class="sm:h-full object-cover object-top transition-transform duration-500 group-hover:scale-[1.03]"
      transition:name={`project-${slug}`}
    />
  </fugure>

  <div class="flex flex-col justify-between p-4 sm:p-5 flex-1 min-w-0">
    <div>
      <div class="flex items-start justify-between gap-3 mb-2">
        <h3 class="text-ink font-semibold leading-snug">
          {title}
        </h3>
        <InternalLinkIcon class:list='stroke-faint group-hover:stroke-lime transition-colors size-5'/>
      </div>
      <p class="text-muted text-sm leading-relaxed line-clamp-3">
        {description}
      </p>
    </div>

    {technologies.length > 0 && (
      <ul
        class="flex flex-wrap gap-1.5 mt-4 list-none"
        role="list"
        aria-label="Technologies"
      >
        {technologies.map(tech => (
          <li>
            <Badge 
              className='group-hover:border-lime/12 group-hover:text-lime'
              size="md"
              label={tech}
            />
          </li>
        ))}
      </ul>
    )}
  </div>
</article>