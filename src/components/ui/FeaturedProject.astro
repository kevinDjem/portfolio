---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets'
import Badge from './Badge.astro';
import CtaButton from './CtaButton.astro';
import GithubIcon from '../icons/tecnologies/GithubIcon.astro';
import { ExternalLinkIcon, InternalLinkIcon } from '../icons/contact';

interface Props {
  project:        CollectionEntry<'projects'>;
  featuredIndex:  number;  // Index within featured array only — drives alternation
}

const { project, featuredIndex } = Astro.props;
const { slug } = project
const { title, description, image, technologies, demoUrl, githubUrl, type } = project.data;

const imageLeft = featuredIndex % 2 === 0;
---

<article
  class="group relative grid grid-cols-1 md:grid-cols-2 rounded-xl overflow-hidden border border-white/6 hover:border-lime/20 transition-colors duration-300"
  aria-label={`Featured project: ${title}`}
>
  {/* Overlay link cubre toda la card */}
  <a
    href={`/project/${slug}`}
    class="absolute inset-0 z-1 rounded-xl"
    aria-label={`Ver detalles de ${title}`}
  />
  <figure
    class:list={[
      'relative overflow-hidden w-full',
      // Mobile: always rendered first in DOM → visually on top
      'order-first',
      // Desktop: flip position based on index
      imageLeft ? 'md:order-1' : 'md:order-2',
      ]}
  >
    <Image
      src={image}
      alt={`Screenshot of ${title}`}
      width={960}
      height={540}
      widths={[320, 640, 960]}
      sizes="(max-width: 480px) 320px, (max-width: 1024px) 640px, 960px"
      quality={80}
      loading="lazy"
      decoding="async"
      format='webp'
      class="sm:h-full object-cover object-top-left transition-transform duration-500 group-hover:scale-[1.04]"
      transition:name={`project-${slug}`}
    />
    {type && (    
      <span
        class="absolute top-3 left-3 font-mono text-[10px] tracking-widest uppercase px-2 py-1 rounded bg-black/70 backdrop-blur-sm text-white/60 border border-white/10"
        aria-label={`Type: ${type}`}
      >
        {type}
      </span>
    )}
  </figure>

  <section
    class:list={[
      'flex flex-col relative justify-between p-6 md:p-8 bg-surface',
      imageLeft ? 'md:order-2' : 'md:order-1',
    ]}
  >
    <article>
      <div class="flex items-start justify-between ">
        <p class="font-mono text-[10px] tracking-[0.2em] uppercase text-lime mb-3">
          Featured · {String(featuredIndex + 1).padStart(2, '0')}
        </p>
        <InternalLinkIcon class:list='stroke-faint group-hover:stroke-lime transition-colors size-5' />
      </div>
      <h3 class="text-ink font-bold mb-3 text-xl md:text-2xl leading-snug">
        {title}
      </h3>
      <p class="text-muted text-sm  leading-relaxed line-clamp-4">
        {description}
      </p>
    </article>
    <article class="mt-6 flex flex-col gap-4">
      {technologies.length > 0 && (
        <ul class="flex flex-wrap gap-1.5 list-none" role="list" aria-label="Technologies">
          {technologies.map(tech => (
            <li>
              <Badge 
                className='group-hover:border-lime/12 group-hover:text-lime'
                size="md"
                label={tech}
              />
            </li>
          ))}
        </ul>
      )}

      {(demoUrl || githubUrl) && (
        <div class="flex max-w-min relative z-10 items-center gap-3 pt-1">
          {githubUrl && (
            <CtaButton 
              href={githubUrl}
              variant="outline-sm"
              className='hover:text-ink'
              target='_blank'
              ariaLabel={`Ver repositorio de GitHub de ${title}`}
            >
              <GithubIcon class:list='size-3.5'/>
              Codigo
            </CtaButton>
          )}
          {demoUrl && (
            <CtaButton
              href={demoUrl}
              variant="outline-sm-white"
              target='_blank'
              ariaLabel={`Ver demo de ${title}`}
            >
              <ExternalLinkIcon class:list="size-3.5 stroke-2"/>
              Demo
            </CtaButton>
          )}
        </div>
      )}
    </article>
  </section>
</article>